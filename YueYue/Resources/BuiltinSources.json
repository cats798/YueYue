{
  "www.biquge365.net": {
    "name": "笔趣阁365",
    "type": "novel",
    "baseURL": "https://www.biquge365.net",
    "searchRule": {
      "url": "/s.php",
      "method": "POST",
      "body": "type=articlename&s=%@&submit=",
      "list": ".result-list .item, .search-list .item",
      "title": "h3 a, .book-title a",
      "urlAttr": "a@href"
    },
    "chapterRule": {
      "list": "#list dd a",
      "title": "a",
      "urlAttr": "a@href"
    },
    "contentRule": {
      "selector": "#content",
      "text": "text"
    },
    "discover": {
      "categories": {
        "玄幻魔法": "/sort/1_1/",
        "仙侠修真": "/sort/2_1/",
        "都市言情": "/sort/3_1/",
        "网游动漫": "/sort/4_1/",
        "科幻小说": "/sort/5_1/",
        "恐怖灵异": "/sort/6_1/",
        "历史军事": "/sort/7_1/",
        "其他类型": "/sort/8_1/"
      },
      "list": ".list-item, .book-list .item",
      "title": "h3 a, .book-title a",
      "urlAttr": "a@href"
    }
  }
}